# Ticketmaster Discovery API — https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# SeatGeek Platform API — https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=your_seatgeek_client_id_here
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret_here

# Eventbrite API — https://www.eventbrite.com/platform/api
EVENTBRITE_API_KEY=your_eventbrite_private_token_here

# Caching (optional)
CACHE_TTL_SECONDS=600
# REDIS_URL=redis://localhost:6379  # Leave blank to use in-memory cache
